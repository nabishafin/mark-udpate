RewriteEngine On

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Shopify Storefront checkout URLs may use the primary domain. On Hostinger,
# those paths must go back to Shopify before the React app fallback runs.
RewriteRule ^products/?$ /index.html [L,QSA]
RewriteRule ^account/reset/(.*)$ /index.html [L,QSA]
RewriteRule ^cart/c/(.*)$ https://orise-6796.myshopify.com/cart/c/$1 [R=302,L,QSA]
RewriteRule ^cart/([0-9].*)$ https://orise-6796.myshopify.com/cart/$1 [R=302,L,QSA]
RewriteRule ^checkouts/(.*)$ https://orise-6796.myshopify.com/checkouts/$1 [R=302,L,QSA]
RewriteRule ^checkout/(.+)$ https://orise-6796.myshopify.com/checkout/$1 [R=302,L,QSA]
RewriteRule ^wallets/checkouts/(.*)$ https://orise-6796.myshopify.com/wallets/checkouts/$1 [R=302,L,QSA]
RewriteRule ^orders/(.*)$ https://orise-6796.myshopify.com/orders/$1 [R=302,L,QSA]
RewriteRule ^([0-9]+)/orders/(.*)$ https://orise-6796.myshopify.com/$1/orders/$2 [R=302,L,QSA]

# Static Apache/Hostinger fallback for website email APIs.
RewriteRule ^api/contact/?$ /api/contact.php [L,QSA]
RewriteRule ^api/email-support/?$ /api/email-support.php [L,QSA]
RewriteRule ^api/marketing-signup/?$ /api/marketing-signup.php [L,QSA]

# Known React/Vite routes. Unknown paths return a real 404 instead of the home page.
RewriteRule ^$ /index.html [L,QSA]
RewriteRule ^(science|science/lab-testing|benefits|athletes-recovery|healthy-aging|shop|products|cart|products/cart|checkout|login|register|forgot-password|reset-password|account|account/orders|research|blogs|blogs/news|contact|learn|founder|pages/refund)/?$ /index.html [L,QSA]
RewriteRule ^(account/orders/.+|account/reset/.+|policies/.+)/?$ /index.html [L,QSA]

# BEGIN GENERATED SEO ROUTES
RewriteRule ^blogs/news/deuterium-depleted-water-immune-support/?$ /index.html [L,QSA]
RewriteRule ^blogs/news/can-deuterium-depleted-water-improve-recovery/?$ /index.html [L,QSA]
RewriteRule ^blogs/news/deuterium-depleted-water-anti-aging/?$ /index.html [L,QSA]
RewriteRule ^blogs/news/deuterium-depleted-water-for-brain-fog/?$ /index.html [L,QSA]
RewriteRule ^blogs/news/does-deuterium-depleted-water-support-metabolism/?$ /index.html [L,QSA]
RewriteRule ^blogs/news/deuterium-depleted-water-for-mitochondria/?$ /index.html [L,QSA]
RewriteRule ^learn/deuterium-mitochondria/?$ /index.html [L,QSA]
RewriteRule ^learn/hydration-recovery/?$ /index.html [L,QSA]
RewriteRule ^learn/hydration-brain-function/?$ /index.html [L,QSA]
RewriteRule ^learn/hydration-gut-health/?$ /index.html [L,QSA]
RewriteRule ^learn/hydration-healthy-aging/?$ /index.html [L,QSA]
RewriteRule ^learn/cellular-energy-performance/?$ /index.html [L,QSA]
# END GENERATED SEO ROUTES

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . - [R=404,L]
